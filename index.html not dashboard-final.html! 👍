<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AVIATOR CASHOUT TRACKER</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&display=swap');
  :root { --green:#00ff9f; --yellow:#ffd600; --red:#ff3d5a; --blue:#00cfff; --bg:#080c10; --panel:#0d1117; --border:#1a2030; }
  * { box-sizing:border-box; margin:0; padding:0; }
  body { background:var(--bg); color:#c8d8e8; font-family:'Rajdhani',sans-serif; min-height:100vh; }

  /* ── LOGIN SCREEN ── */
  #login-screen {
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    min-height:100vh; padding:20px;
  }
  .login-box {
    background:var(--panel); border:1px solid var(--border); border-top:3px solid var(--green);
    border-radius:10px; padding:40px; width:100%; max-width:380px; text-align:center;
  }
  .login-box h2 { font-family:'Share Tech Mono',monospace; color:var(--green); letter-spacing:3px; font-size:18px; margin-bottom:8px; }
  .login-box p { color:#445; font-size:13px; margin-bottom:30px; letter-spacing:1px; }
  .login-box input {
    width:100%; padding:14px; background:#060a0e; border:1px solid var(--border);
    border-radius:6px; color:#eee; font-size:16px; font-family:'Share Tech Mono',monospace;
    letter-spacing:3px; text-align:center; margin-bottom:16px; outline:none;
  }
  .login-box input:focus { border-color:var(--green); }
  .login-box button {
    width:100%; padding:14px; background:var(--green); color:#000; border:none;
    border-radius:6px; font-size:16px; font-weight:bold; letter-spacing:3px;
    cursor:pointer; font-family:'Rajdhani',sans-serif;
  }
  .login-box button:hover { background:#00cc7a; }
  .login-error { color:var(--red); font-size:13px; margin-top:12px; letter-spacing:1px; display:none; }

  /* ── MAIN DASHBOARD ── */
  #main-screen { display:none; padding:20px; }
  .header { display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border); padding-bottom:14px; margin-bottom:24px; }
  .header h1 { font-family:'Share Tech Mono',monospace; font-size:20px; color:var(--green); letter-spacing:3px; }
  .live-dot { width:10px; height:10px; border-radius:50%; background:var(--green); display:inline-block; margin-right:8px; animation:pulse 1.2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .status-text { font-size:12px; color:#556; font-family:'Share Tech Mono',monospace; }
  .logout-btn { background:transparent; border:1px solid #333; color:#445; padding:6px 14px; border-radius:4px; cursor:pointer; font-size:11px; letter-spacing:1px; }
  .logout-btn:hover { border-color:var(--red); color:var(--red); }

  /* Totals row */
  .totals-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px; }
  .total-box { background:var(--panel); border:1px solid var(--border); border-radius:6px; padding:24px; text-align:center; }
  .total-box.this-week { border-top:3px solid var(--green); }
  .total-box.last-week { border-top:3px solid #334; }
  .total-label { font-size:11px; letter-spacing:4px; color:#445; margin-bottom:8px; }
  .total-amount { font-family:'Share Tech Mono',monospace; font-size:48px; color:var(--green); line-height:1; }
  .total-box.last-week .total-amount { color:#445; font-size:36px; }
  .total-amount.flash { color:var(--yellow); }
  .total-currency { font-size:16px; color:#334; margin-top:4px; letter-spacing:2px; }
  .reset-info { font-size:10px; color:#334; margin-top:8px; letter-spacing:1px; }

  .stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:24px; }
  .stat-card { background:var(--panel); border:1px solid var(--border); border-radius:6px; padding:16px 18px; }
  .stat-card .sc-label { font-size:11px; letter-spacing:2px; color:#445; margin-bottom:6px; }
  .stat-card .sc-value { font-family:'Share Tech Mono',monospace; font-size:26px; color:var(--blue); }

  .bottom-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
  .panel { background:var(--panel); border:1px solid var(--border); border-radius:6px; overflow:hidden; }
  .panel-title { padding:10px 16px; font-size:11px; letter-spacing:3px; color:#445; border-bottom:1px solid var(--border); background:#0a0f15; }
  #feed,#tab-table { height:300px; overflow-y:auto; }
  #feed::-webkit-scrollbar,#tab-table::-webkit-scrollbar { width:4px; }
  #feed::-webkit-scrollbar-thumb,#tab-table::-webkit-scrollbar-thumb { background:var(--border); }
  .feed-row { display:flex; justify-content:space-between; align-items:center; padding:7px 16px; border-bottom:1px solid #0d1520; font-size:13px; animation:slideIn 0.3s ease; }
  @keyframes slideIn { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:translateX(0)} }
  .feed-row:hover { background:#111820; }
  .feed-tab { color:#445; font-family:'Share Tech Mono',monospace; font-size:11px; }
  .feed-amt { color:var(--green); font-family:'Share Tech Mono',monospace; font-weight:bold; }
  .feed-time { color:#334; font-size:11px; }
  table { width:100%; border-collapse:collapse; font-size:13px; }
  th { text-align:left; padding:9px 16px; font-size:10px; letter-spacing:2px; color:#334; position:sticky; top:0; background:#0a0f15; border-bottom:1px solid var(--border); }
  td { padding:8px 16px; border-bottom:1px solid #0d1520; font-family:'Share Tech Mono',monospace; }
  tr:hover td { background:#111820; }
  .td-tab { color:#667; }
  .td-active { color:var(--green); }
  .td-count { color:var(--blue); }
  .td-total { color:var(--green); }
  .pulse-dot { width:8px; height:8px; border-radius:50%; background:var(--green); display:inline-block; animation:pulse 1s infinite; margin-right:6px; }
  .empty-state { display:flex; align-items:center; justify-content:center; height:100%; color:#223; font-family:'Share Tech Mono',monospace; font-size:13px; letter-spacing:2px; }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <h2>⚡ AVIATOR TRACKER</h2>
    <p>ENTER PASSWORD TO ACCESS</p>
    <input type="password" id="password-input" placeholder="••••••••" onkeydown="if(event.key==='Enter')login()">
    <button onclick="login()">UNLOCK</button>
    <div class="login-error" id="login-error">❌ WRONG PASSWORD</div>
  </div>
</div>

<!-- MAIN DASHBOARD -->
<div id="main-screen">
  <div class="header">
    <h1>⚡ AVIATOR CASHOUT TRACKER</h1>
    <div style="display:flex;align-items:center;gap:16px;">
      <span class="status-text"><span class="live-dot"></span>LIVE</span>
      <button class="logout-btn" onclick="logout()">LOGOUT</button>
    </div>
  </div>

  <!-- THIS WEEK + LAST WEEK -->
  <div class="totals-row">
    <div class="total-box this-week">
      <div class="total-label">THIS WEEK</div>
      <div class="total-amount" id="total">0</div>
      <div class="total-currency">ZMW</div>
      <div class="reset-info">Resets every Saturday</div>
    </div>
    <div class="total-box last-week">
      <div class="total-label">LAST WEEK</div>
      <div class="total-amount" id="last-week-total">0</div>
      <div class="total-currency">ZMW</div>
      <div class="reset-info">Previous week total</div>
    </div>
  </div>

  <div class="stats-row">
    <div class="stat-card"><div class="sc-label">CASHOUTS</div><div class="sc-value" id="stat-count">0</div></div>
    <div class="stat-card"><div class="sc-label">ACTIVE TABS</div><div class="sc-value" id="stat-tabs">0</div></div>
    <div class="stat-card"><div class="sc-label">AVG / CASHOUT</div><div class="sc-value" id="stat-avg">0</div></div>
  </div>

  <div class="bottom-grid">
    <div class="panel">
      <div class="panel-title">CASHOUT FEED</div>
      <div id="feed"><div class="empty-state">WAITING FOR CASHOUTS...</div></div>
    </div>
    <div class="panel">
      <div class="panel-title">ACTIVE TABS</div>
      <div id="tab-table"><div class="empty-state">NO ACTIVE TABS</div></div>
    </div>
  </div>
</div>

<script>
  let prevTotal = 0;
  let isLoggedIn = sessionStorage.getItem('aviator_auth') === 'true';

  function fmt(n) { return Number(n).toLocaleString('en',{minimumFractionDigits:0}); }
  function timeStr(ts) { return new Date(ts).toTimeString().slice(0,8); }

  function showDashboard() {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('main-screen').style.display = 'block';
    poll();
  }

  function login() {
    const pw = document.getElementById('password-input').value;
    fetch('/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: pw })
    })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        sessionStorage.setItem('aviator_auth', 'true');
        isLoggedIn = true;
        showDashboard();
      } else {
        document.getElementById('login-error').style.display = 'block';
        document.getElementById('password-input').value = '';
      }
    })
    .catch(() => {
      document.getElementById('login-error').style.display = 'block';
    });
  }

  function logout() {
    sessionStorage.removeItem('aviator_auth');
    isLoggedIn = false;
    document.getElementById('login-screen').style.display = 'flex';
    document.getElementById('main-screen').style.display = 'none';
    document.getElementById('password-input').value = '';
  }

  // Auto-login if already authenticated this session
  if (isLoggedIn) showDashboard();

  async function poll() {
    if (!isLoggedIn) return;
    try {
      const res = await fetch('/state');
      const { totalProfit, lastWeekTotal, cashouts, tabs } = await res.json();

      const totalEl = document.getElementById('total');
      totalEl.textContent = fmt(totalProfit);
      if (totalProfit !== prevTotal) {
        totalEl.classList.add('flash');
        setTimeout(() => totalEl.classList.remove('flash'), 600);
        prevTotal = totalProfit;
      }

      document.getElementById('last-week-total').textContent = fmt(lastWeekTotal);

      const activeTabList = Object.entries(tabs);
      const totalCashouts = cashouts.length;
      const avg = totalCashouts > 0 ? Math.round(totalProfit / totalCashouts) : 0;

      document.getElementById('stat-count').textContent = fmt(totalCashouts);
      document.getElementById('stat-tabs').textContent = activeTabList.length;
      document.getElementById('stat-avg').textContent = fmt(avg);

      const feedEl = document.getElementById('feed');
      if (cashouts.length === 0) {
        feedEl.innerHTML = '<div class="empty-state">WAITING FOR CASHOUTS...</div>';
      } else {
        feedEl.innerHTML = cashouts.map(c => `
          <div class="feed-row">
            <span class="feed-tab">TAB ${c.tabId}</span>
            <span class="feed-amt">+${fmt(c.amount)} ZMW</span>
            <span class="feed-time">${timeStr(c.timestamp)}</span>
          </div>`).join('');
      }

      const tabEl = document.getElementById('tab-table');
      if (activeTabList.length === 0) {
        tabEl.innerHTML = '<div class="empty-state">NO ACTIVE TABS</div>';
      } else {
        tabEl.innerHTML = `
          <table>
            <thead><tr><th>TAB</th><th>STATUS</th><th>CASHOUTS</th><th>TOTAL</th></tr></thead>
            <tbody>
              ${activeTabList.map(([id, t]) => `
                <tr>
                  <td class="td-tab">${id}</td>
                  <td class="td-active"><span class="pulse-dot"></span>ACTIVE</td>
                  <td class="td-count">${t.count}</td>
                  <td class="td-total">${fmt(t.total)} ZMW</td>
                </tr>`).join('')}
            </tbody>
          </table>`;
      }
    } catch(e) {}
    setTimeout(poll, 1000);
  }
</script>
</body>
</html>
